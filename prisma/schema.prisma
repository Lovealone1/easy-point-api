generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMINISTRATOR
  COLLABORATOR
  USER
}

enum GlobalRole {
  ADMIN
  MODERATOR
  USER
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  firstName   String?
  lastName    String?
  phoneNumber String?
  isActive    Boolean    @default(true)
  globalRole  GlobalRole @default(USER)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  organizations         OrganizationUser[]
  employee              Employee?
  inventoryMovements    InventoryMovement[]
  supplyMovements       SupplyMovement[]
  financialTransactions FinancialTransaction[]
  supplyPurchases       SupplyPurchase[]
  productPurchases      ProductPurchase[]
  sales                 Sale[]

  @@map("users")
}

model Organization {
  id              String             @id @default(uuid())
  name            String
  slug            String?            @unique
  email           String?
  plan            Plan               @default(FREE)
  planActiveUntil DateTime?
  status          OrganizationStatus @default(ACTIVE)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  members               OrganizationUser[]
  invitations           Invitation[]
  clients               Client[]
  suppliers             Supplier[]
  employees             Employee[]
  supplies              Supply[]
  productCategories     ProductCategory[]
  products              Product[]
  recipes               Recipe[]
  productStocks         ProductStock[]
  inventoryMovements    InventoryMovement[]
  supplyStocks          SupplyStock[]
  supplyMovements       SupplyMovement[]
  bankAccounts          BankAccount[]
  financialTransactions FinancialTransaction[]
  supplyPurchases       SupplyPurchase[]
  productPurchases      ProductPurchase[]
  sales                 Sale[]
  transactionCategories TransactionCategory[]

  @@map("organizations")
}

model OrganizationUser {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           Role     @default(USER)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_users")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  token     String           @unique
  role      Role
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([email])
  @@index([organizationId])
  @@map("invitations")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

model Client {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  taxId          String?
  email          String?
  phone          String
  address        String?
  creditLimit    Decimal @db.Decimal(10, 2)

  isActive   Boolean    @default(true)
  clientType ClientType @default(INDIVIDUAL)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales        Sale[]

  @@index([organizationId])
  @@map("clients")
}

model Supplier {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  taxId          String
  email          String
  phone          String
  address        String
  bankAccount    String?
  leadTime       Int

  isActive     Boolean @default(true)
  paymentTerms String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplyPurchases  SupplyPurchase[]
  productPurchases ProductPurchase[]

  @@index([organizationId])
  @@map("suppliers")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

model Employee {
  id             String   @id @default(uuid())
  organizationId String
  firstName      String
  lastName       String
  taxId          String?
  salary         Decimal  @db.Decimal(10, 2)
  hireDate       DateTime
  position       String

  email    String?
  phone    String?
  status   EmployeeStatus @default(ACTIVE)
  isActive Boolean        @default(true)
  notes    String?
  userId   String?        @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("employees")
}

enum UnitOfMeasure {
  GRAM
  MILLILITER
  UNIT
  KILOGRAM
  LITER
}

model Supply {
  id          String  @id @default(uuid())
  name        String
  description String?

  unitOfMeasure UnitOfMeasure
  packageSize   Decimal       @db.Decimal(12, 4)
  basePrice     Decimal       @db.Decimal(12, 2)

  pricePerUnit Decimal @db.Decimal(12, 4)

  isActive       Boolean      @default(true)
  notes          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries    SupplyStock[]
  supplyMovements SupplyMovement[]

  @@index([organizationId])
  @@index([name])
  @@map("supplies")
}

model ProductCategory {
  id             String @id @default(uuid())
  organizationId String

  name String

  code String @db.Char(3)

  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("product_categories")
}

model Product {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?

  sku String? @unique

  barcode String?

  salePrice Decimal @db.Decimal(12, 2)

  costPrice Decimal? @db.Decimal(12, 2)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  isPurchased Boolean @default(false)

  recipeId String? @unique
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  imageUrl String?
  notes    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stockEntries       ProductStock[]
  inventoryMovements InventoryMovement[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([sku])
  @@map("products")
}

model Recipe {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?

  content Json

  category String?

  estimatedTime Int?

  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  product Product?

  @@index([organizationId])
  @@index([category])
  @@map("recipes")
}

model ProductStock {
  id             String @id @default(uuid())
  organizationId String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  location String @default("Principal")

  quantity Decimal @default(0) @db.Decimal(12, 4)

  minQuantity Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]

  @@unique([productId, location])
  @@index([organizationId])
  @@index([productId])
  @@map("product_stocks")
}

enum MovementType {
  SALE
  PRODUCTION
  PURCHASE
  ADJUSTMENT
  WASTE
  TESTS
}

model InventoryMovement {
  id             String @id @default(uuid())
  organizationId String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  stockId String
  stock   ProductStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  quantity Decimal @db.Decimal(12, 4)

  unitCost Decimal? @db.Decimal(12, 4)

  type   MovementType
  reason String?

  productPurchaseId String?
  productPurchase   ProductPurchase? @relation(fields: [productPurchaseId], references: [id], onDelete: SetNull)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  referenceId       String?
  referenceType     String?
  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@index([stockId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

model SupplyStock {
  id             String @id @default(uuid())
  organizationId String

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  location String @default("Principal")

  quantity Decimal @default(0) @db.Decimal(12, 4)

  minQuantity Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplyMovements SupplyMovement[]

  @@unique([supplyId, location])
  @@index([organizationId])
  @@index([supplyId])
  @@map("supply_stocks")
}

enum SupplyMovementType {
  PURCHASE
  PRODUCTION
  ADJUSTMENT
  WASTE
  TESTS
}

model SupplyMovement {
  id             String @id @default(uuid())
  organizationId String

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  stockId String
  stock   SupplyStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  quantity Decimal @db.Decimal(12, 4)

  unitCost Decimal? @db.Decimal(12, 4)

  type   SupplyMovementType
  reason String?

  supplyPurchaseId String?
  supplyPurchase   SupplyPurchase? @relation(fields: [supplyPurchaseId], references: [id], onDelete: SetNull)

  referenceId       String?
  referenceType     String?
  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([supplyId])
  @@index([stockId])
  @@index([type])
  @@index([createdAt])
  @@map("supply_movements")
}

enum BankAccountStatus {
  ACTIVE
  FROZEN
  INACTIVE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum OperationType {
  SALE
  PURCHASE
  REFUND
  TRANSFER
  ADJUSTMENT
}

model BankAccount {
  id             String @id @default(uuid())
  organizationId String

  name     String
  balance  Decimal @default(0) @db.Decimal(19, 4)
  currency String  @default("COP") @db.Char(3)

  version Int @default(1)

  accountNumber String?
  qrCode        String?

  status BankAccountStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([organizationId])
  @@map("bank_accounts")
}

model FinancialTransaction {
  id             String @id @default(uuid())
  organizationId String

  transactionNumber String

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  type   TransactionType
  amount Decimal         @db.Decimal(19, 4)

  balanceBefore Decimal @db.Decimal(19, 4)
  balanceAfter  Decimal @db.Decimal(19, 4)

  operationType OperationType
  referenceId   String?
  referenceType String?

  categoryId String?
  category   TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  paymentMethod PaymentMethod?

  description String?

  metadata Json?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplyPurchase  SupplyPurchase?
  productPurchase ProductPurchase?
  sale            Sale?

  @@unique([organizationId, transactionNumber])
  @@index([organizationId])
  @@index([bankAccountId])
  @@index([type])
  @@index([operationType])
  @@index([createdAt])
  @@map("financial_transactions")
}

enum PurchaseStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model SupplyPurchase {
  id             String @id @default(uuid())
  organizationId String

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  totalAmount Decimal @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status PurchaseStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    SupplyMovement[]

  @@index([organizationId])
  @@index([supplierId])
  @@map("supply_purchases")
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model ProductPurchase {
  id             String @id @default(uuid())
  organizationId String

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  totalAmount Decimal @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status PurchaseStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    InventoryMovement[]

  @@index([organizationId])
  @@index([supplierId])
  @@map("product_purchases")
}

model Sale {
  id             String @id @default(uuid())
  organizationId String

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  totalAmount Decimal @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status SaleStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    InventoryMovement[]

  @@index([organizationId])
  @@index([clientId])
  @@map("sales")
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CHECK
  OTHER
}

enum TransactionCategoryType {
  INCOME
  EXPENSE
}

model TransactionCategory {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?
  type        TransactionCategoryType

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@unique([organizationId, name, type])
  @@index([organizationId])
  @@map("transaction_categories")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// enum Role replaced by model Role in feature/11

enum GlobalRole {
  ADMIN
  MODERATOR
  USER
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  firstName   String?
  lastName    String?
  phoneNumber String?
  isActive    Boolean    @default(true)
  globalRole  GlobalRole @default(USER)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  organizations         OrganizationUser[]
  employee              Employee?
  inventoryMovements    InventoryMovement[]
  supplyMovements       SupplyMovement[]
  financialTransactions FinancialTransaction[]
  supplyPurchases       SupplyPurchase[]
  productPurchases      ProductPurchase[]
  sales                 Sale[]
  productions           Production[]
  refreshTokens         RefreshToken[]
  createdDiscountRules  DiscountRule[]
  appliedDiscounts      AppliedDiscount[]
  personaNaturalBilling   PersonaNaturalBilling?
  personaJuridicaBilling  PersonaJuridicaBilling?

  @@map("users")
}

model Organization {
  id        String             @id @default(uuid())
  name      String
  slug      String?            @unique
  email     String?
  status    OrganizationStatus @default(ACTIVE)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  members               OrganizationUser[]
  config                OrganizationConfig?
  invitations           Invitation[]
  clients               Client[]
  suppliers             Supplier[]
  employees             Employee[]
  supplies              Supply[]
  productCategories     ProductCategory[]
  products              Product[]
  recipes               Recipe[]
  productStocks         ProductStock[]
  inventoryMovements    InventoryMovement[]
  supplyStocks          SupplyStock[]
  supplyStockEntries    SupplyStockEntry[]
  supplyMovements       SupplyMovement[]
  bankAccounts          BankAccount[]
  financialTransactions FinancialTransaction[]
  supplyPurchases       SupplyPurchase[]
  productPurchases      ProductPurchase[]
  sales                 Sale[]
  transactionCategories TransactionCategory[]
  productions           Production[]
  saleUtilities         SaleUtility[]
  saleItemUtilities     SaleItemUtility[]
  roles                 Role[]
  rolePermissions       RolePermission[]
  discountRules         DiscountRule[]
  appliedDiscounts      AppliedDiscount[]
  organizationModules   OrganizationModule[]
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  subscriptions         Subscription[]
  invoices              Invoice[]

  @@map("organizations")
}

model OrganizationUser {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  roleId         String
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_users")
}

model OrganizationConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // UI & Branding
  logoUrl      String?
  logoShortUrl String?
  primaryColor String? @default("#000000")
  defaultTheme Theme   @default(SYSTEM)

  // Regional settings
  timezone   String @default("UTC")
  currency   String @default("USD")
  language   String @default("es")
  dateFormat String @default("DD/MM/YYYY")

  // Business info
  taxId         String?
  address       String?
  phone         String?
  receiptFooter String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_configs")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  token     String           @unique
  roleId    String
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([email])
  @@index([organizationId])
  @@map("invitations")
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

model Client {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  taxId          String?
  email          String?
  phone          String
  address        String?
  creditLimit    Decimal @db.Decimal(10, 2)

  isActive   Boolean    @default(true)
  clientType ClientType @default(INDIVIDUAL)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales         Sale[]
  discountRules DiscountRule[]

  @@index([organizationId])
  @@map("clients")
}

model Supplier {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  taxId          String
  email          String
  phone          String
  address        String
  bankAccount    String?
  leadTime       Int

  isActive     Boolean @default(true)
  paymentTerms String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplyPurchases  SupplyPurchase[]
  productPurchases ProductPurchase[]

  @@index([organizationId])
  @@map("suppliers")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

model Employee {
  id             String   @id @default(uuid())
  organizationId String
  firstName      String
  lastName       String
  taxId          String?
  salary         Decimal  @db.Decimal(10, 2)
  hireDate       DateTime
  position       String

  email    String?
  phone    String?
  status   EmployeeStatus @default(ACTIVE)
  isActive Boolean        @default(true)
  notes    String?
  userId   String?        @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("employees")
}

enum UnitOfMeasure {
  GRAM
  MILLILITER
  UNIT
}

model Supply {
  id          String  @id @default(uuid())
  name        String
  description String?

  unitOfMeasure UnitOfMeasure
  packageSize   Decimal       @db.Decimal(12, 4)
  basePrice     Decimal       @db.Decimal(12, 2)

  pricePerUnit Decimal @db.Decimal(12, 4)

  isActive       Boolean      @default(true)
  notes          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries     SupplyStock[]
  supplyMovements  SupplyMovement[]
  productionUsages ProductionSupplyUsage[]

  @@index([organizationId])
  @@index([name])
  @@map("supplies")
}

model ProductCategory {
  id             String @id @default(uuid())
  organizationId String

  name String

  code String @db.Char(3)

  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("product_categories")
}

model Product {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?

  sku String? @unique

  barcode String?

  salePrice Decimal @db.Decimal(12, 2)

  costPrice Decimal? @db.Decimal(12, 2)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  isPurchased Boolean @default(false)

  recipeId String? @unique
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  imageUrl String?
  notes    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stockEntries       ProductStock[]
  inventoryMovements InventoryMovement[]
  productions        Production[]
  saleItemUtilities  SaleItemUtility[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([sku])
  @@map("products")
}

model Recipe {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?

  content Json

  category String?

  estimatedTime Int?

  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  product Product?

  @@index([organizationId])
  @@index([category])
  @@map("recipes")
}

model ProductStock {
  id             String @id @default(uuid())
  organizationId String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  location String @default("Principal")

  quantity Decimal @default(0) @db.Decimal(12, 4)

  minQuantity Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryMovements InventoryMovement[]

  @@unique([productId, location])
  @@index([organizationId])
  @@index([productId])
  @@map("product_stocks")
}

enum MovementType {
  SALE
  PRODUCTION
  PURCHASE
  ADJUSTMENT
  WASTE
  TESTS
}

model InventoryMovement {
  id             String @id @default(uuid())
  organizationId String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  stockId String
  stock   ProductStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  quantity Decimal @db.Decimal(12, 4)

  unitCost Decimal? @db.Decimal(12, 4)

  type   MovementType
  reason String?

  productPurchaseId String?
  productPurchase   ProductPurchase? @relation(fields: [productPurchaseId], references: [id], onDelete: SetNull)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  productionId String?
  production   Production? @relation(fields: [productionId], references: [id], onDelete: SetNull)

  referenceId       String?
  referenceType     String?
  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@index([stockId])
  @@index([type])
  @@index([productionId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model SupplyStock {
  id             String @id @default(uuid())
  organizationId String

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  location String @default("Principal")

  quantity Decimal @default(0) @db.Decimal(12, 4)

  minQuantity Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplyMovements SupplyMovement[]
  entries         SupplyStockEntry[]

  @@unique([supplyId, location])
  @@index([organizationId])
  @@index([supplyId])
  @@map("supply_stocks")
}

enum SupplyMovementType {
  PURCHASE
  PRODUCTION
  ADJUSTMENT
  WASTE
  TESTS
}

model SupplyMovement {
  id             String @id @default(uuid())
  organizationId String

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  stockId String
  stock   SupplyStock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  quantity Decimal @db.Decimal(12, 4)

  unitCost Decimal? @db.Decimal(12, 4)

  type   SupplyMovementType
  reason String?

  supplyPurchaseId String?
  supplyPurchase   SupplyPurchase? @relation(fields: [supplyPurchaseId], references: [id], onDelete: SetNull)

  productionId String?
  production   Production? @relation(fields: [productionId], references: [id], onDelete: SetNull)

  referenceId       String?
  referenceType     String?
  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([supplyId])
  @@index([stockId])
  @@index([type])
  @@index([productionId])
  @@index([createdAt])
  @@map("supply_movements")
}

enum BankAccountStatus {
  ACTIVE
  FROZEN
  INACTIVE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum OperationType {
  SALE
  PURCHASE
  REFUND
  TRANSFER
  ADJUSTMENT
  EXPENSE
}

model BankAccount {
  id             String @id @default(uuid())
  organizationId String

  name     String
  balance  Decimal @default(0) @db.Decimal(19, 4)
  currency String  @default("COP") @db.Char(3)

  version Int @default(1)

  accountNumber String?
  qrCode        String?

  status BankAccountStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]
  expenses     Expense[]

  @@index([organizationId])
  @@map("bank_accounts")
}

model FinancialTransaction {
  id             String @id @default(uuid())
  organizationId String

  transactionNumber String

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)

  type   TransactionType
  amount Decimal         @db.Decimal(19, 4)

  balanceBefore Decimal @db.Decimal(19, 4)
  balanceAfter  Decimal @db.Decimal(19, 4)

  operationType OperationType
  referenceId   String?
  referenceType String?

  categoryId String?
  category   TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  paymentMethod PaymentMethod?

  description String?

  metadata Json?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  supplyPurchase  SupplyPurchase?
  productPurchase ProductPurchase?
  sale            Sale?
  expense         Expense?

  @@unique([organizationId, transactionNumber])
  @@index([organizationId])
  @@index([bankAccountId])
  @@index([type])
  @@index([operationType])
  @@index([createdAt])
  @@map("financial_transactions")
}

enum PurchaseStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model SupplyPurchase {
  id             String @id @default(uuid())
  organizationId String

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  totalAmount Decimal @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status PurchaseStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    SupplyMovement[]
  stockEntries SupplyStockEntry[]

  @@index([organizationId])
  @@index([supplierId])
  @@map("supply_purchases")
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model ProductPurchase {
  id             String @id @default(uuid())
  organizationId String

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  totalAmount Decimal @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status PurchaseStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements    InventoryMovement[]

  @@index([organizationId])
  @@index([supplierId])
  @@map("product_purchases")
}

model Sale {
  id             String @id @default(uuid())
  organizationId String

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  subtotalAmount Decimal? @db.Decimal(19, 4)
  discountAmount Decimal? @db.Decimal(19, 4)
  totalAmount    Decimal  @db.Decimal(19, 4)

  transactionId String?               @unique
  transaction   FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  status SaleStatus @default(COMPLETED)
  notes  String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  movements       InventoryMovement[]
  saleUtility     SaleUtility?
  appliedDiscount AppliedDiscount?

  @@index([organizationId])
  @@index([clientId])
  @@map("sales")
}

enum CostSource {
  PRODUCTION
  ESTIMATED
  UNKNOWN
}

model SaleUtility {
  id             String @id @default(uuid())
  organizationId String

  saleId String @unique
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  totalRevenue  Decimal @db.Decimal(19, 4)
  totalCost     Decimal @db.Decimal(19, 4)
  grossProfit   Decimal @db.Decimal(19, 4)
  marginPercent Decimal @db.Decimal(8, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        SaleItemUtility[]

  @@index([organizationId])
  @@index([createdAt])
  @@map("sale_utilities")
}

model SaleItemUtility {
  id             String @id @default(uuid())
  organizationId String

  saleUtilityId String
  saleUtility   SaleUtility @relation(fields: [saleUtilityId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity      Decimal    @db.Decimal(12, 4)
  unitRevenue   Decimal    @db.Decimal(12, 4)
  unitCost      Decimal    @db.Decimal(12, 4)
  totalRevenue  Decimal    @db.Decimal(19, 4)
  totalCost     Decimal    @db.Decimal(19, 4)
  grossProfit   Decimal    @db.Decimal(19, 4)
  marginPercent Decimal    @db.Decimal(8, 4)
  costSource    CostSource

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([saleUtilityId])
  @@index([productId])
  @@index([organizationId])
  @@index([createdAt])
  @@map("sale_item_utilities")
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CHECK
  OTHER
}

enum TransactionCategoryType {
  INCOME
  EXPENSE
}

model TransactionCategory {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?
  type        TransactionCategoryType

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@unique([organizationId, name, type])
  @@index([organizationId])
  @@map("transaction_categories")
}

enum ProductionType {
  SELLABLE
  INTERMEDIATE
}

enum ProductionStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model SupplyStockEntry {
  id             String @id @default(uuid())
  organizationId String

  supplyStockId String
  supplyStock   SupplyStock @relation(fields: [supplyStockId], references: [id], onDelete: Cascade)

  supplyPurchaseId String?
  supplyPurchase   SupplyPurchase? @relation(fields: [supplyPurchaseId], references: [id], onDelete: SetNull)

  initialQuantity   Decimal @db.Decimal(12, 4)
  remainingQuantity Decimal @db.Decimal(12, 4)

  unitCost    Decimal @db.Decimal(12, 4)
  isExhausted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productionUsages ProductionSupplyUsage[]

  @@index([supplyStockId])
  @@index([organizationId])
  @@index([isExhausted])
  @@map("supply_stock_entries")
}

model Production {
  id             String @id @default(uuid())
  organizationId String

  name           String
  productionDate DateTime

  type   ProductionType   @default(SELLABLE)
  status ProductionStatus @default(DRAFT)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  quantityProduced Decimal       @db.Decimal(12, 4)
  unitOfMeasure    UnitOfMeasure

  totalCost Decimal @default(0) @db.Decimal(19, 4)

  notes String?

  performedByUserId String?
  performedBy       User?   @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplyUsages ProductionSupplyUsage[]

  inventoryMovements InventoryMovement[]

  supplyMovements SupplyMovement[]

  @@index([organizationId])
  @@index([productId])
  @@index([productionDate])
  @@index([status])
  @@map("productions")
}

model ProductionSupplyUsage {
  id           String     @id @default(uuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  supplyId String
  supply   Supply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  supplyStockEntryId String?
  supplyStockEntry   SupplyStockEntry? @relation(fields: [supplyStockEntryId], references: [id], onDelete: SetNull)
  quantityUsed       Decimal           @db.Decimal(12, 4)
  unitCost           Decimal           @db.Decimal(12, 4)

  totalCost Decimal @db.Decimal(12, 4)

  createdAt DateTime @default(now())

  @@index([productionId])
  @@index([supplyId])
  @@index([supplyStockEntryId])
  @@map("production_supply_usages")
}

model Role {
  id              String  @id @default(uuid())
  organizationId  String
  name            String // Ej: 'OWNER', 'ADMINISTRATOR', 'COLLABORATOR', 'USER', 'CAJERO'
  description     String?
  isSystemDefault Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  users           OrganizationUser[]
  invitations     Invitation[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@map("roles")
}

// ─── Tipos de permiso ────────────────────────────────────────────────────────

enum PermissionType {
  CRUD // create, read, update, delete sobre un recurso
  ACTION // acciones de negocio específicas (cancel, approve, complete)
  VIEW // visibilidad de datos sensibles (costos, salarios, crédito)
  UI // control de elementos visuales (botones, tabs, columnas)
}

// ─── Catálogo de módulos — seed data, inmutable en runtime ───────────────────

model Module {
  id          String  @id @default(uuid())
  key         String  @unique // ej: "sales", "inventory", "employees"
  name        String // ej: "Ventas", "Inventario"
  description String?
  icon        String? // nombre del icono para el UI
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  features            Feature[]
  organizationModules OrganizationModule[]

  @@map("modules")
}

// ─── Features dentro de un módulo — seed data ─────────────────────────────────

model Feature {
  id       String @id @default(uuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  key         String  @unique // ej: "sales.management", "sales.reports"
  name        String // ej: "Gestión de Ventas"
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  permissions Permission[]

  @@index([moduleId])
  @@map("features")
}

// ─── Catálogo de permisos atómicos — seed data, referenciados por key ─────────

model Permission {
  id        String  @id @default(uuid())
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  key         String         @unique // ej: "sales:create", "employees:view_salary"
  name        String // ej: "Crear venta"
  description String?
  type        PermissionType // CRUD | ACTION | VIEW | UI
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)

  rolePermissions RolePermission[]

  @@index([featureId])
  @@map("permissions")
}

// ─── Asignación dinámica de permisos a roles (por organización) ──────────────

model RolePermission {
  id String @id @default(uuid())

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Denormalizado para queries eficientes sin join adicional a Role
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  grantedAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([organizationId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG — Append-only compliance & traceability store
// ─────────────────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  ROLE_CHANGE
  PERMISSION_CHANGE
  EXPORT
  CANCEL
  API_KEY_CHANGE
  TENANT_CONFIG_CHANGE
  SESSION_KILL
  CUSTOM
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model AuditLog {
  id             String        @id @default(uuid())
  tenantId       String
  userId         String?
  impersonatedBy String?
  action         AuditAction
  resourceType   String
  resourceId     String?
  before         Json?
  after          Json?
  changedFields  Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  sessionId      String?
  severity       AuditSeverity @default(LOW)
  createdAt      DateTime      @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, action])
  @@index([tenantId, severity])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum DiscountScope {
  GLOBAL
  CLIENT
}

enum DiscountCategory {
  ONE_TIME
  PERIODIC
}

model DiscountRule {
  id             String @id @default(uuid())
  organizationId String

  name              String
  description       String?
  code              String
  type              DiscountType
  value             Decimal          @db.Decimal(12, 4)
  scope             DiscountScope
  clientId          String?
  category          DiscountCategory
  startsAt          DateTime?
  expiresAt         DateTime?
  maxDiscountAmount Decimal?         @db.Decimal(19, 4)
  minSaleAmount     Decimal?         @db.Decimal(19, 4)
  maxUsages         Int?
  usageCount        Int              @default(0)

  isActive Boolean @default(true)
  notes    String?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  appliedDiscounts AppliedDiscount[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([clientId])
  @@index([category])
  @@index([isActive])
  @@index([expiresAt])
  @@map("discount_rules")
}

model AppliedDiscount {
  id             String @id @default(uuid())
  organizationId String

  saleId String @unique
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  discountRuleId String?
  discountRule   DiscountRule? @relation(fields: [discountRuleId], references: [id], onDelete: SetNull)

  discountType  DiscountType
  discountValue Decimal      @db.Decimal(12, 4)

  discountAmount Decimal @db.Decimal(19, 4)

  originalAmount Decimal @db.Decimal(19, 4)
  finalAmount    Decimal @db.Decimal(19, 4)

  reason String?

  appliedByUserId String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appliedBy    User?        @relation(fields: [appliedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([discountRuleId])
  @@index([createdAt])
  @@map("applied_discounts")
}

model OrganizationModule {
  id             String   @id @default(uuid())
  organizationId String
  moduleId       String
  assignedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([organizationId, moduleId])
  @@index([organizationId])
  @@index([moduleId])
  @@map("organization_modules")
}

model ExpenseCategory {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("expense_categories")
}

model Expense {
  id             String   @id @default(uuid())
  organizationId String
  categoryId     String
  bankAccountId  String
  amount         Decimal  @db.Decimal(19, 4)
  description    String?
  transactionId  String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bankAccount  BankAccount           @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  transaction  FinancialTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([categoryId])
  @@index([bankAccountId])
  @@map("expenses")
}

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique // e.g. "Free", "Basic", "Premium"
  description  String?
  monthlyPrice Decimal  @db.Decimal(12, 2)
  yearlyPrice  Decimal  @db.Decimal(12, 2)
  currency     String   @default("COP") @db.Char(3)
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  TRIALING
  PENDING_PAYMENT
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
  OVERDUE
}

model Subscription {
  id             String @id @default(uuid())
  organizationId String
  planId         String

  billingCycle BillingCycle
  status       SubscriptionStatus @default(ACTIVE)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  trialEndsAt DateTime?
  cancelledAt DateTime?
  isPaused    Boolean   @default(false)
  pausedAt    DateTime?
  notes       String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices     Invoice[]

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Invoice {
  id             String @id @default(uuid())
  organizationId String
  subscriptionId String

  invoiceNumber String @unique // e.g. "INV-2026-001"

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("COP") @db.Char(3)

  status  InvoiceStatus @default(PENDING)
  dueDate DateTime
  paidAt  DateTime?

  // Trazabilidad del pago manual (a cuenta independiente)
  paymentReference String? // # transferencia, recibo, etc.
  paymentMethod    String? // "Nequi", "Bancolombia", "Efectivo", etc. (libre)
  paymentNotes     String?

  billingPeriodStart DateTime
  billingPeriodEnd   DateTime

  metadata Json?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("invoices")
}

model PersonaNaturalBilling {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  tipoDocumento           String   // "CC", "CE", "PA", "NIT"
  numeroDocumento         String
  primerNombre            String
  primerApellido          String
  tipoPersonaNacionalidad String   // "Nacional", "Extranjero"
  responsabilidadesFiscales String // Códigos separados por comas, ej: "O-13, O-15"
  regimenTributario       String   // "Régimen Común", "Régimen Simple de Tributación", "No responsable de IVA"
  regimenFiscalIva        String   // "Responsable de IVA", "No responsable de IVA"
  correoElectronicoRut    String
  direccion               String
  departamento            String
  municipio               String
  certificadoFirma        String   // Certificado de firma digital (ruta/URL/base64)
  modoOperacion           String   // "Proveedor Tecnológico", "Desarrollo Propio", "Facturación Gratuita DIAN"
  prefijoNumeracion       String
  rangoDesde              Int
  rangoHasta              Int
  resolucionDian          String
  fechaResolucion         DateTime
  fechaVigencia           DateTime
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("persona_natural_billing")
}

model PersonaJuridicaBilling {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  tipoDocumento           String   // "NIT"
  numeroNit               String
  digitoVerificacion      String
  razonSocial             String
  tipoOrganizacion        String   // "S.A.S.", "S.A.", "Ltda.", "Cooperativa", "Fundación", "ESAL", "Otra"
  codigoCiiu              String
  repLegalTipoDoc         String   // "CC", "CE", "PA"
  repLegalNumeroDoc       String
  repLegalNombres         String
  repLegalApellidos       String
  repLegalEmail           String
  responsabilidadesFiscales String
  regimenTributario       String   // "Régimen Ordinario", "Régimen Simple de Tributación"
  regimenFiscalIva        String   // "Responsable de IVA", "No responsable de IVA"
  correoElectronicoRut    String
  direccion               String
  departamento            String
  municipio               String
  certificadoFirma        String
  modoOperacion           String   // "Proveedor Tecnológico", "Desarrollo Propio", "Facturación Gratuita DIAN"
  prefijoNumeracion       String
  rangoDesde              Int
  rangoHasta              Int
  resolucionDian          String
  fechaResolucion         DateTime
  fechaVigencia           DateTime
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("persona_juridica_billing")
}
